{
  "name": "Nexora Theme",
  "type": "dark",

  "colors": {
    // ========================
    // 🧱 BASE EDITOR
    // ========================
    "editor.background": "#0A0B0D",
    "editor.foreground": "#E6E9EF",
    "editor.lineHighlightBackground": "#121417",

    // ========================
    // 🎯 CURSOR & SELECTION
    // ========================
    "editorCursor.foreground": "#E05A5A",
    "editor.selectionBackground": "#1A1D22",

    // ========================
    // 📏 INDENT GUIDES
    // ========================
    "editorIndentGuide.background1": "#1E2228",
    "editorIndentGuide.activeBackground1": "#2A2F38",

    // ========================
    // 📁 SIDEBAR
    // ========================
    "sideBar.background": "#0A0B0D",
    "sideBar.foreground": "#8B92A1",
    "sideBar.border": "#1E2228",

    "tree.indentGuidesStroke": "#1E2228",
    // ========================
    // 🧭 ACTIVITY BAR
    // ========================
    "activityBar.background": "#0A0B0D",
    "activityBar.foreground": "#E05A5A",
    "activityBar.border": "#1E2228",

    // ========================
    // 📋 LISTS & SELECTIONS
    // ========================
    "list.activeSelectionBackground": "#121417",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.inactiveSelectionBackground": "#0A0B0D",
    "list.hoverBackground": "#0A0B0D",
    "list.inactiveSelectionForeground": "#8B92A1",
    // "list.hoverBackground": "#121417",
    "list.focusOutline": "#E05A5A",

    "list.focusBackground": "#121417",
    "list.focusForeground": "#FFFFFF",

    // ========================
    // 🔴 STATUS BAR (BOTTOM)
    // ========================
    "statusBar.background": "#E05A5A",
    "statusBar.foreground": "#0A0B0D",
    "statusBar.noFolderBackground": "#E05A5A",
    "statusBar.debuggingBackground": "#C94A4A",
    "statusBar.border": "#1E2228",

    "statusBarItem.hoverBackground": "#C94A4A",
    "statusBarItem.activeBackground": "#B84343",

    // ========================
    // 🧠 TITLE BAR (TOP)
    // ========================
    "titleBar.activeBackground": "#0A0B0D",
    "titleBar.activeForeground": "#E6E9EF",
    "titleBar.inactiveBackground": "#0A0B0D",
    "titleBar.inactiveForeground": "#E6E9EF",
    "titleBar.border": "#1E2228",

    // ========================
    // 📑 TABS
    // ========================
    "tab.activeBackground": "#0A0B0D",
    "tab.inactiveBackground": "#0A0B0D",
    "tab.activeForeground": "#E6E9EF",
    "tab.inactiveForeground": "#6B7280",
    "tab.border": "#1E2228",

    // ========================
    // 📦 PANELS
    // ========================
    "panel.background": "#0A0B0D",
    "panel.border": "#1E2228",

    // ========================
    // 📜 SCROLLBAR
    // ========================
    "scrollbarSlider.background": "#1E2228",
    "scrollbarSlider.hoverBackground": "#2A2F38",

    // ========================
    // ⚠️ FEEDBACK (ERRORS / WARNINGS)
    // ========================
    "editorError.foreground": "#FF5C5C",
    "editorWarning.foreground": "#F0B35A",
    "editorInfo.foreground": "#3ECF8E",

    // ========================
    // 🔘 BUTTONS
    // ========================
    "button.background": "#E05A5A",
    "button.foreground": "#0A0B0D",
    "button.hoverBackground": "#C94A4A",

    "button.secondaryBackground": "#1E2228",
    "button.secondaryForeground": "#E6E9EF",
    "button.secondaryHoverBackground": "#2A2F38",

    "button.border": "#1E2228",

    // ========================
    // ⌨️ INPUTS & DROPDOWNS
    // ========================
    "input.background": "#121417",
    "input.foreground": "#E6E9EF",
    "input.border": "#1E2228",
    "input.placeholderForeground": "#6B7280",

    "dropdown.background": "#121417",
    "dropdown.foreground": "#E6E9EF",
    "dropdown.border": "#1E2228",

    // ========================
    // 🎯 FOCUS & INTERACTION
    // ========================
    "focusBorder": "#E05A5A",

    // ========================
    // ☑️ CHECKBOX
    // ========================
    "checkbox.background": "#121417",
    "checkbox.border": "#1E2228",
    "checkbox.foreground": "#E05A5A",

    // ========================
    // ⚡ QUICK INPUT (CMD PALETTE)
    // ========================
    "quickInput.background": "#0A0B0D",
    "quickInput.foreground": "#E6E9EF",

    "quickInputList.focusBackground": "#121417",
    "quickInputList.focusForeground": "#FFFFFF",

    // ========================
    // 🔗 LINKS & BADGES
    // ========================
    "textLink.foreground": "#FF6B6B",
    "textLink.activeForeground": "#E05A5A",

    "badge.background": "#E05A5A",
    "badge.foreground": "#0A0B0D",

    // ========================
    // 💬 HOVER
    // ========================
    "editorHoverWidget.background": "#121417",
    "editorHoverWidget.border": "#1E2228"
  },

  // ========================
  // 🧠 TOKEN COLORS (CÓDIGO)
  // ========================
  "tokenColors": [
    // ========================
    // 💬 COMMENTS
    // ========================
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6B7280",
        "fontStyle": "italic"
      }
    },

    // ========================
    // 🔑 KEYWORDS
    // ========================
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#E05A5A"
      }
    },

    // ========================
    // ⚙️ FUNCTIONS
    // ========================
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },

    // ========================
    // 🧩 VARIABLES
    // ========================
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#E6E9EF"
      }
    },

    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#E6E9EF"
      }
    },

    // ========================
    // 🔢 NUMBERS / CONSTANTS
    // ========================
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#F0B35A"
      }
    },

    {
      "name": "Constants",
      "scope": ["constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#F0B35A"
      }
    },

    // ========================
    // 🧵 STRINGS
    // ========================
    {
      "name": "Strings",
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#A3BE8C"
      }
    },

    // ========================
    // 🧱 CLASSES / TYPES
    // ========================
    {
      "name": "Classes",
      "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type"],
      "settings": {
        "foreground": "#E8A55A"
      }
    },

    // ========================
    // 🔗 PROPERTIES
    // ========================
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.object-literal.key"],
      "settings": {
        "foreground": "#D1D5DB"
      }
    },

    // ========================
    // 🔣 OPERATORS
    // ========================
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.control"],
      "settings": {
        "foreground": "#8B92A1"
      }
    },

    // ========================
    // 🧷 PUNCTUATION
    // ========================
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#6B7280"
      }
    },

    // ========================
    // 🟨 JAVASCRIPT / TYPESCRIPT
    // ========================
    {
      "name": "JS/TS Functions",
      "scope": [
        "source.js entity.name.function",
        "source.ts entity.name.function",
        "meta.function-call.js",
        "meta.function-call.ts"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "name": "JS/TS Variables",
      "scope": ["source.js variable", "source.ts variable"],
      "settings": {
        "foreground": "#E6E9EF"
      }
    },
    {
      "name": "JS/TS Keywords",
      "scope": ["source.js keyword", "source.ts keyword"],
      "settings": {
        "foreground": "#E05A5A"
      }
    },
    {
      "name": "JS/TS this / special",
      "scope": ["variable.language.this.js", "variable.language.this.ts"],
      "settings": {
        "foreground": "#F0B35A"
      }
    },

    // ========================
    // ⚛️ REACT / JSX / TSX
    // ========================
    {
      "name": "React Components",
      "scope": ["source.jsx entity.name.tag", "source.tsx entity.name.tag"],
      "settings": {
        "foreground": "#E8A55A"
      }
    },
    {
      "name": "JSX Props",
      "scope": ["source.jsx entity.other.attribute-name", "source.tsx entity.other.attribute-name"],
      "settings": {
        "foreground": "#E05A5A"
      }
    },
    {
      "name": "JSX Strings",
      "scope": ["source.jsx string", "source.tsx string"],
      "settings": {
        "foreground": "#A3BE8C"
      }
    },

    // ========================
    // 🐍 PYTHON
    // ========================
    {
      "name": "Python Functions",
      "scope": ["source.python entity.name.function"],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "name": "Python Classes",
      "scope": ["source.python entity.name.type.class"],
      "settings": {
        "foreground": "#E8A55A"
      }
    },
    {
      "name": "Python Keywords",
      "scope": ["source.python keyword"],
      "settings": {
        "foreground": "#E05A5A"
      }
    },
    {
      "name": "Python Builtins",
      "scope": ["support.function.builtin.python"],
      "settings": {
        "foreground": "#F0B35A"
      }
    },

    // ========================
    // 🌐 HTML
    // ========================
    {
      "name": "HTML Tags",
      "scope": ["text.html.basic entity.name.tag"],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": ["text.html.basic entity.other.attribute-name"],
      "settings": {
        "foreground": "#E05A5A"
      }
    },
    {
      "name": "HTML Strings",
      "scope": ["text.html.basic string"],
      "settings": {
        "foreground": "#A3BE8C"
      }
    },

    // ========================
    // 📝 MARKDOWN
    // ========================
    {
      "name": "Markdown Headings",
      "scope": ["markup.heading", "markup.heading.markdown"],
      "settings": {
        "foreground": "#FF6B6B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#E05A5A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#E8A55A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#A3BE8C"
      }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#FF6B6B",
        "fontStyle": "underline"
      }
    }
  ]
}
